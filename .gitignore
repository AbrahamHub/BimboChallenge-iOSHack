# Ignorar datasets grandes que no deben estar en el repo
Model/grupo-bimbo-inventory-demand/*.csv

# Ignorar archivos derivados y temporales de Xcode
*/DerivedData/
*.xcuserstate
# No ignorar "*.xcworkspace" globalmente: oculta también `*.xcodeproj/project.xcworkspace`
# (workspace embebido que Xcode usa para Swift Packages y puede estabilizar el PIF).
*.xcuserdata/

# CocoaPods / Carthage / SPM artifacts
/Pods/
/Carthage/
.build/

# macOS
.DS_Store

# Swift Package Manager
/.build

